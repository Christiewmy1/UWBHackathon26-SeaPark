{
  "expo": {
    "name": "SeaPark",
    "slug": "seapark",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/seapark-logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/seapark-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.seapark.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/seapark-logo.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.seapark.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
